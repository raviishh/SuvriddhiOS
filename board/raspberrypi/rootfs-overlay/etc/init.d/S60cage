#!/bin/sh

start() {
    export XDG_RUNTIME_DIR=/tmp/runtime-root
    export CHROME_DATA_DIR=/root/chromium-data
    mkdir -p $XDG_RUNTIME_DIR $CHROME_DATA_DIR
    chmod 0700 $XDG_RUNTIME_DIR $CHROME_DATA_DIR
    export LD_LIBRARY_PATH=/usr/lib/chromium-browser:$LD_LIBRARY_PATH

    echo "Starting network setup..."
    ip link set wlan0 up 2>/dev/null || true
    if [ -f /etc/wpa_supplicant.conf ] && grep -q "ssid" /etc/wpa_supplicant.conf; then
        wpa_supplicant -B -i wlan0 -c /etc/wpa_supplicant.conf 2>/dev/null || true
        udhcpc -i wlan0 2>/dev/null || true
        ntpd -g -q -p pool.ntp.org 2>/dev/null || true
    else
        echo "No WiFi config found, skipping network setup"
    fi

    /root/server & 
    busybox httpd -h /root/www -p 8080 &
    busybox httpd -h /root/www/build -p 8081 &
    busybox httpd -h /root/www/learn -p 8082 &

    sleep 5

    exec cage -- /usr/lib/chromium-browser/chromium-browser \
        --noerrdialogs \
        --disable-infobars \
        --no-sandbox \
        --ozone-platform=wayland \
        --user-data-dir=$CHROME_DATA_DIR \
        --disable-dev-shm-usage \
        --disable-extensions \
        --disable-background-networking \
        --disable-sync \
        --disable-translate \
        --renderer-process-limit=2 \
        --process-per-site \
        --js-flags="--max-old-space-size=256" \
        --purge-memory-after-idle \
        --disable-features=SafeBrowsing,Translate,BackgroundFetch,MediaRouter,WaylandFractionalScale,Vulkan,UseChromeOSDirectVideoDecoder \
        --disable-speech-api \
        --disable-speech-synthesis \
        --enable-webgl \
        --ignore-gpu-blocklist \
        --disable-gpu-compositing \
        --enable-features=VaapiVideoDecoder \
        --user-agent="Mozilla/5.0 (Linux; Android 13; Pixel 7) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/116.0.0.0 Mobile Safari/537.36" \
        --enable-accelerated-video-decode \
        --num-raster-threads=2 \
        http://127.0.0.1:8080
}

stop() {
    killall chromium-browser 2>/dev/null
    killall httpd 2>/dev/null
    killall cage 2>/dev/null
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; sleep 1; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac

#!/bin/sh

start() {
    # 1. Environment & Permissions
    export XDG_RUNTIME_DIR=/tmp/runtime-root
    export CHROME_DATA_DIR=/tmp/runtime-chromium
    mkdir -p $XDG_RUNTIME_DIR $CHROME_DATA_DIR
    chmod 0700 $XDG_RUNTIME_DIR $CHROME_DATA_DIR
    
    # Prioritize fix libraries
    export LD_LIBRARY_PATH=/usr/lib/chromium-browser:$LD_LIBRARY_PATH

    # 2. Background Services
    # Commented out server since we confirmed it isn't needed for this demo
    # /root/server & 
    busybox httpd -h /root/www -p 8080 &

    sleep 5
    
    # 3. Launch Kiosk (Optimized for 1GB Pi & Unity WebGL)
    exec cage -- /usr/lib/chromium-browser/chromium-browser \
        --start-fullscreen \
        --noerrdialogs \
        --disable-infobars \
        --no-sandbox \
        --ozone-platform=wayland \
        --enable-features=UseOzonePlatform \
        --use-gl=egl \
        --user-data-dir=$CHROME_DATA_DIR \
        --disable-dev-shm-usage \
        --max_old_space_size=512 \
        --ignore-gpu-blocklist \
        --enable-webgl \
        --disable-webgl-image-chromium \
        --enable-gpu-rasterization \
        --force-gpu-rasterization \
        --disable-gpu-vsync \
        --disable-features=GpuProcessHighPriority \
        --single-process \
        --disable-low-res-tiling \
        http://127.0.0.1:8080
}

stop() {
    killall chromium-browser 2>/dev/null
    killall httpd 2>/dev/null
    killall cage 2>/dev/null
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; sleep 1; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
